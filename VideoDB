var VIDEO_RENAME_CONFIG = {
  sheetName: "출석부",
  portalDbSheetName: "PortalDB",
  videoDbSheetName: "영상DB",
  daysToScan: 14,
  dryRun: true
};

function batchRenameRecentVideos() {
  var lock = LockService.getScriptLock();
  if (!lock.tryLock(1000)) {
    Logger.log("SKIP: 이전 실행이 아직 끝나지 않아 이번 실행을 건너뜁니다.");
    return;
  }

  try {
    batchRenameRecentVideos_(VIDEO_RENAME_CONFIG);
  } finally {
    lock.releaseLock();
  }
}

function batchRenameRecentVideosDryRun() {
  batchRenameRecentVideos_({
    sheetName: "출석부",
    portalDbSheetName: "PortalDB",
    videoDbSheetName: "영상DB",
    daysToScan: 14,
    dryRun: true
  });
}

